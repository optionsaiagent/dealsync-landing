---
// Blog index — lists posts. Add new entries here as they're published.
const posts = [
  {
    slug: "the-follow-up-gap",
    title: "The Follow-Up Gap: Why Good Mortgage Referrals Quietly Die",
    description: "Most mortgage referrals don't die at closing. They die in the weeks after a great first call. Here's why — and how to close the gap.",
    pubDate: "June 28, 2026",
    readingTime: "7 min read",
  },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0B1D2E" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&display=swap" />
    <title>Blog — DealSync</title>
    <meta name="description" content="Field notes on the LO–Realtor partnership, lead nurturing, and the follow-up gap — from the team behind DealSync." />
    <link rel="canonical" href="https://www.dealsync.me/blog" />
    <style>
      :root { --navy:#0B1D2E; --navy-light:#132B42; --teal:#00D4AA; --white:#F0F4F8; --ghost:rgba(240,244,248,0.6); --ghost-dim:rgba(240,244,248,0.4); --border:rgba(240,244,248,0.1); --font:'DM Sans',sans-serif; --display:'Fraunces',serif; }
      * { box-sizing:border-box; margin:0; padding:0; }
      body { background:var(--navy); color:var(--ghost); font-family:var(--font); line-height:1.7; -webkit-font-smoothing:antialiased; }
      a { color:var(--teal); text-decoration:none; } a:hover { opacity:.85; }
      .nav { max-width:760px; margin:0 auto; padding:28px 24px; display:flex; justify-content:space-between; align-items:center; }
      .logo { font-family:var(--display); font-size:22px; font-weight:600; }
      .logo .deal { color:var(--teal); } .logo .sync { color:var(--white); font-weight:300; }
      .nav a.cta { background:var(--teal); color:var(--navy); padding:8px 18px; border-radius:8px; font-size:13px; font-weight:600; }
      main { max-width:760px; margin:0 auto; padding:20px 24px 70px; }
      .eyebrow { color:var(--teal); font-size:12px; font-weight:600; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:14px; }
      h1 { font-family:var(--display); font-weight:700; font-size:40px; letter-spacing:-1px; color:var(--white); margin-bottom:10px; }
      .lede { font-size:16px; color:var(--ghost); margin-bottom:40px; }
      .post { display:block; padding:24px; border:1px solid var(--border); border-radius:14px; background:var(--navy-light); margin-bottom:16px; }
      .post:hover { border-color:rgba(0,212,170,0.3); opacity:1; }
      .post h2 { font-family:var(--display); font-weight:600; font-size:22px; color:var(--white); margin-bottom:8px; line-height:1.3; }
      .post p { font-size:14.5px; color:var(--ghost); margin-bottom:10px; }
      .post .meta { font-size:12px; color:var(--ghost-dim); }
      footer { max-width:760px; margin:0 auto; padding:30px 24px 50px; border-top:1px solid var(--border); font-size:13px; color:var(--ghost-dim); }
      footer a { color:var(--ghost-dim); }
    </style>
  </head>
  <body>
    <nav class="nav">
      <a href="/" class="logo"><span class="deal">Deal</span><span class="sync">Sync</span></a>
      <a href="https://app.dealsync.me" class="cta">Start free trial</a>
    </nav>
    <main>
      <div class="eyebrow">DealSync Blog</div>
      <h1>Field notes</h1>
      <p class="lede">On the LO–Realtor partnership, lead nurturing, and the follow-up gap — from a 25-year loan officer.</p>
      {posts.map((p) => (
        <a class="post" href={`/blog/${p.slug}`}>
          <h2>{p.title}</h2>
          <p>{p.description}</p>
          <div class="meta">{p.pubDate} · {p.readingTime}</div>
        </a>
      ))}
    </main>
    <footer>
      © 2026 DealSync.me · <a href="/">Home</a> · <a href="/privacy.html">Privacy</a> · <a href="/terms.html">Terms</a>
    </footer>
  </body>
</html>
